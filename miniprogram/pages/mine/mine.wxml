<!-- 我的 -->
<view class="page">
  <!-- 用户卡片 -->
  <view class="user-card">
    <view class="user-avatar">{{profile.avatar}}</view>
    <text class="user-name">{{profile.nickname}}</text>
    <text class="user-bio" wx:if="{{profile.bio}}">{{profile.bio}}</text>
    <navigator url="/pages/profile/profile" class="edit-link">✏️ 编辑资料</navigator>
  </view>

  <!-- 我发布的 -->
  <view class="section">
    <view class="sec-hd">
      <text class="sec-title">📋 我发布的组队</text>
      <text class="sec-count">{{published.length}}条</text>
    </view>
    <view class="mini-team" wx:for="{{published}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <view class="mt-left">
        <text class="mt-song">🎤 {{item.combo_name}} · {{item.song_name}}</text>
        <text class="mt-info">{{item.member_count}}/{{item.max_members}}人 · {{item.status === 'active' ? '组队中' : (item.status === 'completed' ? '已完成' : '已取消')}}</text>
      </view>
      <text class="mt-arrow">→</text>
    </view>
    <view class="empty-mini" wx:if="{{published.length === 0}}">
      <text>还没有发布过组队</text>
    </view>
  </view>

  <!-- 我报名的 -->
  <view class="section">
    <view class="sec-hd">
      <text class="sec-title">🚀 我报名的组队</text>
      <text class="sec-count">{{joined.length}}条</text>
    </view>
    <view class="mini-team" wx:for="{{joined}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <view class="mt-left">
        <text class="mt-song">🎤 {{item.combo_name}} · {{item.song_name}}</text>
        <text class="mt-info">{{item.member_count}}/{{item.max_members}}人</text>
      </view>
      <text class="mt-arrow">→</text>
    </view>
    <view class="empty-mini" wx:if="{{joined.length === 0}}">
      <text>还没有报名任何组队</text>
    </view>
  </view>

  <!-- 申请中 -->
  <view class="section" wx:if="{{applying.length > 0}}">
    <view class="sec-hd">
      <text class="sec-title">📩 申请中</text>
      <text class="sec-count">{{applying.length}}条</text>
    </view>
    <view class="mini-team" wx:for="{{applying}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <view class="mt-left">
        <text class="mt-song">🎤 {{item.combo_name}} · {{item.song_name}}</text>
        <text class="mt-info">等待车主审核中...</text>
      </view>
      <text class="mt-arrow">→</text>
    </view>
  </view>

  <!-- 我跳过的舞 -->
  <view class="section" wx:if="{{danced.length > 0}}">
    <view class="sec-hd">
      <text class="sec-title">📸 我跳过的舞</text>
      <text class="sec-count">{{danced.length}}支</text>
    </view>
    <view class="mini-team" wx:for="{{danced}}" wx:key="id">
      <view class="mt-left">
        <text class="mt-song">✅ {{item.combo_name}} · {{item.song_name}}</text>
        <text class="mt-info">{{item.performance_time}}</text>
      </view>
    </view>
  </view>

  <!-- 关于 -->
  <view class="section" style="margin-bottom:40rpx;">
    <text class="sec-title">ℹ️ 关于</text>
    <text class="about-text">🎵 KPOP深圳组队 v2.2</text>
    <text class="about-text">帮助深圳 Kpop 舞者快速找到路演搭子</text>
  </view>
</view>
