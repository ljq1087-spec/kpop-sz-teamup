<!-- 发布组队 -->
<view class="page">
  <view class="form-card">
    <text class="form-title">🎵 发布组队信息</text>
    <text class="form-sub">填写信息，快速找到路演搭子！</text>

    <!-- 组合类型 -->
    <view class="form-group">
      <text class="form-label">🎭 组合类型 <text class="required">*</text></text>
      <view class="opt-row">
        <view class="opt {{comboType === 'boy' ? 'active' : ''}}" bindtap="setComboType" data-type="boy">🕺 男团</view>
        <view class="opt {{comboType === 'girl' ? 'active' : ''}}" bindtap="setComboType" data-type="girl">💃 女团</view>
        <view class="opt {{comboType === 'mixed' ? 'active' : ''}}" bindtap="setComboType" data-type="mixed">👫 混合团</view>
      </view>
    </view>

    <!-- 组合名 -->
    <view class="form-group" wx:if="{{comboType}}">
      <text class="form-label">🎤 组合名 <text class="required">*</text></text>
      <input class="form-input" placeholder="输入组合名，或从下方热门选择" value="{{comboName}}" bindinput="onInput" data-field="comboName"/>
      <view class="hot-combos" wx:if="{{hotCombos.length > 0}}">
        <view class="hot-combo {{comboName === item ? 'active' : ''}}" wx:for="{{hotCombos}}" wx:key="*this" bindtap="pickCombo" data-name="{{item}}">{{item}}</view>
      </view>
    </view>

    <!-- 歌曲名 -->
    <view class="form-group">
      <text class="form-label">🎵 歌曲名 <text class="required">*</text></text>
      <input class="form-input" placeholder="如：Iconic、Supernova..." value="{{songName}}" bindinput="onInput" data-field="songName"/>
    </view>

    <!-- 缺位 -->
    <view class="form-group">
      <text class="form-label">🎯 还缺什么位置 <text class="required">*</text></text>
      <view class="pos-input-wrap">
        <input class="form-input" placeholder="如：karina位、winter位" value="{{posInput}}" bindinput="onInput" data-field="posInput" bindconfirm="addPos"/>
        <view class="add-btn" bindtap="addPos">添加</view>
      </view>
      <view class="chip-row" wx:if="{{positions.length > 0}}">
        <view class="chip" wx:for="{{positions}}" wx:key="*this">
          <text>{{item}}</text>
          <text class="chip-x" bindtap="delPos" data-index="{{index}}">✕</text>
        </view>
      </view>
    </view>

    <!-- 我跳的位置 -->
    <view class="form-group">
      <text class="form-label">🙋 我跳的位置（车主） <text class="required">*</text></text>
      <input class="form-input" placeholder="如：你跳 karina位 / 你负责主舞" value="{{myPart}}" bindinput="onInput" data-field="myPart"/>
    </view>

    <!-- 排练时间 -->
    <view class="form-group">
      <text class="form-label">📅 排练时间 <text class="required">*</text></text>
      <input class="form-input" placeholder="如：8月7日晚、周六下午" value="{{rehearsal}}" bindinput="onInput" data-field="rehearsal"/>
    </view>

    <!-- 路演时间 -->
    <view class="form-group">
      <text class="form-label">🎬 路演时间 <text class="required">*</text></text>
      <input class="form-input" placeholder="如：8月8日、周日下午" value="{{performance}}" bindinput="onInput" data-field="performance"/>
    </view>

    <!-- 地点（多选） -->
    <view class="form-group">
      <text class="form-label">📍 排练地点 <text class="required">*</text></text>
      <text class="form-hint">可多选，勾选「排练地点可协商」表示地点待定</text>
      <view class="loc-opts">
        <view class="loc-opt {{locations.includes('civic') ? 'active' : ''}}" bindtap="toggleLocation" data-loc="civic">🏛️ 市民中心</view>
        <view class="loc-opt {{locations.includes('studio') ? 'active' : ''}}" bindtap="toggleLocation" data-loc="studio">🪩 自助舞室</view>
        <view class="loc-opt {{locations.includes('community') ? 'active' : ''}}" bindtap="toggleLocation" data-loc="community">🏢 党群中心</view>
        <view class="loc-opt {{locations.includes('negotiable') ? 'active' : ''}}" bindtap="toggleLocation" data-loc="negotiable">🤝 排练地点可协商</view>
      </view>
      <input class="form-input" wx:if="{{locations.includes('studio') || locations.includes('community') || locations.includes('negotiable')}}" style="margin-top: 14rpx;" placeholder="补充具体位置，或注明可协商" value="{{locationNote}}" bindinput="onInput" data-field="locationNote"/>
    </view>

    <!-- 人数 -->
    <view class="form-group">
      <text class="form-label">👥 人数</text>
      <view class="stepper">
        <view class="step-btn {{maxMembers <= 1 ? 'disabled' : ''}}" bindtap="stepMembers" data-delta="-1">−</view>
        <text class="step-val">{{maxMembers}}</text>
        <view class="step-btn {{maxMembers >= 20 ? 'disabled' : ''}}" bindtap="stepMembers" data-delta="1">+</view>
      </view>
    </view>

    <!-- 审核 -->
    <view class="form-group">
      <text class="form-label">🛡️ 上车审核 <text class="required">*</text></text>
      <view class="audit-opts">
        <view class="audit-opt on-none {{audit === 'none' ? 'active' : ''}}" bindtap="setAudit" data-level="none">🟢 无审核</view>
        <view class="audit-opt on-light {{audit === 'light' ? 'active' : ''}}" bindtap="setAudit" data-level="light">🔵 微审</view>
        <view class="audit-opt on-medium {{audit === 'medium' ? 'active' : ''}}" bindtap="setAudit" data-level="medium">🟡 中审</view>
        <view class="audit-opt on-medium_strict {{audit === 'medium_strict' ? 'active' : ''}}" bindtap="setAudit" data-level="medium_strict">🟠 中严审</view>
        <view class="audit-opt on-strict {{audit === 'strict' ? 'active' : ''}}" bindtap="setAudit" data-level="strict">🔴 严审</view>
      </view>
      <view class="audit-desc">{{auditDesc}}</view>
    </view>

    <!-- 备注（带提示） -->
    <view class="form-group">
      <text class="form-label">📝 备注</text>
      <view class="note-hints">
        <text class="nh-title">💡 建议填写以下信息：</text>
        <text class="nh-item" wx:for="{{noteHints}}" wx:key="*this">{{item}}</text>
      </view>
      <textarea class="form-textarea" placeholder="参考上方提示填写备注..." value="{{notes}}" bindinput="onInput" data-field="notes"/>
    </view>

    <!-- 提交 -->
    <button class="btn btn-primary btn-block" bindtap="submit" loading="{{submitting}}" style="margin-top: 12rpx;">🚀 发布组队</button>
  </view>
</view>
