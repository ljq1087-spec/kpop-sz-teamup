<!-- 组队详情 -->
<view class="page" wx:if="{{team}}">
  <!-- 头部 -->
  <view class="dt-head">
    <text class="dt-status {{team.status === 'completed' ? 'done' : ''}} {{team.status === 'cancelled' ? 'cancelled' : ''}}">
      {{team.status === 'completed' ? '✅ 已完队' : (team.status === 'cancelled' ? '❌ 已取消' : '🔥 组队中')}}
    </text>
    <text class="dt-type">{{comboTypeEmoji}} {{comboTypeName}} · {{team.combo_name}}</text>
    <text class="dt-song">🎤 {{team.song_name}}</text>
    <text class="dt-creator">{{team.creator_nickname || '匿名'}} 发布</text>
  </view>

  <!-- 审核等级 -->
  <view class="audit-banner ban-{{team.audit_level}}">
    <text class="ab-title">{{auditEmoji}} 上车审核：{{auditName}}</text>
    <text class="ab-desc">{{auditDesc}}</text>
  </view>

  <!-- 缺位 -->
  <view class="section">
    <text class="sec-title">🎯 还缺什么位置</text>
    <view class="pos-tags">
      <text class="pos-tag" wx:for="{{team.missing_positions}}" wx:key="*this">{{item}}</text>
      <text class="pos-empty" wx:if="{{team.missing_positions.length === 0}}">暂无缺位</text>
    </view>
  </view>

  <!-- 完整时间信息（需求1） -->
  <view class="section">
    <text class="sec-title">⏰ 时间安排</text>
    <view class="info-block">
      <text class="ib-label">📅 排练时间</text>
      <text class="ib-value">{{team.rehearsal_time}}</text>
    </view>
    <view class="info-block">
      <text class="ib-label">🎬 路演时间</text>
      <text class="ib-value">{{team.performance_time}}</text>
    </view>
  </view>

  <!-- 完整地点信息（需求1、6、13） -->
  <view class="section">
    <text class="sec-title">📍 排练地点</text>
    <view class="loc-list">
      <text class="loc-item" wx:for="{{locationNames}}" wx:key="*this">📍 {{item}}</text>
    </view>
    <text class="loc-note" wx:if="{{team.location_note}}">💬 {{team.location_note}}</text>
  </view>

  <!-- 完整备注（需求1） -->
  <view class="section" wx:if="{{team.notes}}">
    <text class="sec-title">📝 备注</text>
    <text class="notes-full">{{team.notes}}</text>
  </view>

  <!-- 已上车成员（需求4、9：隐私 + 简介权限） -->
  <view class="section">
    <text class="sec-title">👥 已上车 ({{team.member_count}}/{{team.max_members}})</text>
    <text class="privacy-hint" wx:if="{{team.has_joined || team.is_creator}}">💡 {{team.is_creator ? '你是车主，可查看所有成员微信' : '同车后可查看队友微信'}}</text>
    <text class="privacy-hint" wx:else>🔒 组队成功后可见队友微信和简介</text>

    <view class="member-item" wx:for="{{team.members}}" wx:key="openid" bindtap="onMemberTap" data-openid="{{item.openid}}" data-index="{{index}}">
      <view class="m-avatar {{item.openid === team.creator_openid ? 'creator' : ''}}">{{item.nickname ? item.nickname[0] : '👤'}}</view>
      <view class="m-info">
        <text class="m-name">{{item.nickname || '匿名'}}{{item.openid === 'dev_user_001' ? '（我）' : ''}}</text>
        <text class="m-part" wx:if="{{item.part}}">跳 {{item.part}}</text>
        <!-- 车主微信始终可见；组队完成后所有成员微信可见 -->
        <text class="m-wx" wx:if="{{(item.openid === team.creator_openid) || (team.status === 'completed' && (team.has_joined || team.is_creator))}}" bindtap="copyWx" catchtap="copyWx" data-wx="{{item.wechat}}">💬 微信：{{item.wechat || '未填写'}}</text>
      </view>
      <text class="m-tag" wx:if="{{item.openid === team.creator_openid}}">车主</text>
      <!-- 车主可管理成员（需求5） -->
      <view class="m-manage" wx:if="{{team.is_creator && item.openid !== 'dev_user_001' && team.status === 'active'}}" catchtap="showMemberMenu" data-openid="{{item.openid}}" data-part="{{item.part}}">
        <text>⚙️</text>
      </view>
    </view>

    <view class="progress-bar">
      <view class="progress-fill" style="width: {{team.member_count / team.max_members * 100}}%"></view>
    </view>
    <text class="progress-text">还差 {{team.max_members - team.member_count}} 人满员</text>
  </view>

  <!-- 找替信息区（需求3） -->
  <view class="section" wx:if="{{team.substitutes && team.substitutes.length > 0}}">
    <text class="sec-title">🔄 找替信息</text>
    <view class="sub-item" wx:for="{{team.substitutes}}" wx:key="id">
      <view class="sub-head">
        <text class="sub-part">🎯 {{item.part}}</text>
        <text class="sub-status sub-{{item.status}}">{{item.status === 'open' ? '寻找中' : (item.status === 'confirmed' ? '已确认替身' : '已关闭')}}</text>
      </view>
      <text class="sub-note" wx:if="{{item.note}}">💬 {{item.note}}</text>
      <view class="sub-actions" wx:if="{{item.status === 'open'}}">
        <button class="btn btn-outline btn-sm" bindtap="applySubstitute" data-sub-id="{{item.id}}">🙋 我来当替身</button>
      </view>
      <view class="sub-apps" wx:if="{{team.is_creator && item.applicants && item.applicants.length > 0}}">
        <text class="sa-title">申请当替身的人：</text>
        <view class="sa-item" wx:for="{{item.applicants}}" wx:key="openid" wx:for-item="app">
          <text>{{app.nickname || '匿名'}}</text>
          <button class="btn btn-success btn-sm" bindtap="confirmSub" data-sub-id="{{item.id}}" data-openid="{{app.openid}}">确认</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 待审核申请（车主可见，需求7：显示简介） -->
  <view class="section" wx:if="{{team.is_creator && pendingApps.length > 0}}" style="border-color:rgba(192,132,252,0.25);">
    <text class="sec-title">📩 待审核申请 ({{pendingApps.length}})</text>
    <view class="app-item" wx:for="{{pendingApps}}" wx:key="openid">
      <view class="app-head">
        <view class="m-avatar" style="margin-right:16rpx;">{{item.nickname ? item.nickname[0] : '👤'}}</view>
        <view class="m-info">
          <text class="m-name">{{item.nickname || '匿名'}}</text>
          <text class="m-part">想跳：{{item.part || '未填写'}}</text>
          <text class="m-bio" wx:if="{{item.bio}}">📝 {{item.bio}}</text>
        </view>
      </view>
      <view class="app-video" bindtap="viewVideo" data-url="{{item.video_url}}">
        <text>▶️</text>
        <text class="vu-text">{{item.video_url && item.video_url.indexOf('[本地]') === 0 ? '📹 已上传视频' : (item.video_url || '未提供视频')}}</text>
      </view>
      <view class="app-msg" wx:if="{{item.message}}">
        <text class="am-label">💬 附言：</text>
        <text class="am-text">"{{item.message}}"</text>
      </view>
      <view class="app-acts">
        <button class="btn btn-danger-outline btn-sm" bindtap="goReject" data-openid="{{item.openid}}">委婉拒绝</button>
        <button class="btn btn-success btn-sm" bindtap="reviewApp" data-openid="{{item.openid}}" data-approve="1">✅ 接受组队</button>
      </view>
    </view>
  </view>

  <view style="height:280rpx;"></view>

  <!-- 底部操作栏 -->
  <view class="bottom-actions">
    <!-- 无审核直接上车 -->
    <view class="act-row" wx:if="{{!team.has_joined && !team.is_creator && team.audit_level === 'none' && (!myApp || myApp.status === 'rejected') && myRejectCount < 2 && team.status === 'active'}}">
      <input class="join-input" placeholder="你跳什么位置？" value="{{joinPart}}" bindinput="onJoinInput"/>
      <button class="btn btn-primary" style="white-space:nowrap;flex-shrink:0;" bindtap="doJoin">🚀 上车</button>
    </view>

    <!-- 有审核申请（需求10：附带一句话，需求11：拒绝两次限制） -->
    <view class="apply-wrap" wx:if="{{!team.has_joined && !team.is_creator && team.audit_level !== 'none' && (!myApp || myApp.status === 'rejected') && myRejectCount < 2 && team.status === 'active'}}">
      <text class="aw-title">📹 申请上车（需车主审核）</text>
      <view class="opt-row">
        <view class="opt {{applyMode === 'upload' ? 'active' : ''}}" bindtap="setApplyMode" data-mode="upload">📹 上传视频</view>
        <view class="opt {{applyMode === 'link' ? 'active' : ''}}" bindtap="setApplyMode" data-mode="link">🔗 视频链接</view>
      </view>
      <view class="upload-box {{videoVal ? 'done' : ''}}" wx:if="{{applyMode === 'upload'}}" bindtap="mockUpload">
        {{videoVal ? '✅ 已选择：' + videoVal : '⬆️ 点击上传舞蹈视频'}}
      </view>
      <input wx:if="{{applyMode === 'link'}}" class="join-input" placeholder="舞蹈视频链接（抖音/B站/视频号）" value="{{videoVal}}" bindinput="onVideoInput"/>
      <input class="join-input" placeholder="想跳的位置？（如：karina位）" value="{{joinPart}}" bindinput="onJoinInput"/>
      <input class="join-input" placeholder="给车主留一句话（选填）" value="{{applyMessage}}" bindinput="onMsgInput"/>
      <text class="aw-hint">💡 视频仅车主可见 · 被拒绝两次后无法再申请</text>
      <button class="btn btn-primary btn-block" bindtap="doApply">📩 提交申请</button>
    </view>

    <!-- 被拒绝两次 -->
    <view class="status-wrap" wx:if="{{myRejectCount >= 2 && !team.has_joined && !team.is_creator}}">
      <text class="sw-rejected">🚫 已被拒绝两次，无法再次申请该队伍</text>
    </view>

    <!-- 待审核 -->
    <view class="status-wrap" wx:if="{{myApp && myApp.status === 'pending'}}">
      <text class="sw-pending">⏳ 申请已提交，等待车主审核...</text>
    </view>

    <!-- 被拒绝 -->
    <view class="status-wrap" wx:if="{{myApp && myApp.status === 'rejected' && myRejectCount < 2}}">
      <text class="sw-rejected">😢 这次没通过，车主说：</text>
      <view class="reject-msg">"{{myApp.reject_msg || '这次坑位已满，期待下次同车～'}}"</view>
      <button class="btn btn-primary btn-block" bindtap="reapply">重新申请（还剩 {{2 - myRejectCount}} 次）</button>
    </view>

    <!-- 已上车：可以发起找替（需求3） -->
    <view class="joined-row" wx:if="{{team.has_joined && !team.is_creator && team.status === 'active'}}">
      <text class="joined-text">✅ 你已上车</text>
      <button class="btn btn-outline btn-sm" bindtap="goFindSubstitute">🔄 找人替我</button>
      <button class="btn btn-danger-outline btn-sm" bindtap="doLeave">下车</button>
    </view>

    <!-- 车主操作 -->
    <view class="creator-row" wx:if="{{team.is_creator && team.status === 'active'}}">
      <button class="btn btn-success btn-sm" wx:if="{{team.member_count >= 2}}" bindtap="doComplete">✅ 组队完成</button>
      <button class="btn btn-danger-outline btn-sm" bindtap="doCancel">❌ 取消组队</button>
    </view>

    <!-- 已完成的队伍可重新开放（需求8） -->
    <view class="status-wrap" wx:if="{{team.status === 'completed'}}">
      <text style="color:var(--green);font-size:28rpx;font-weight:600;display:block;margin-bottom:16rpx;">🎉 这支舞已经跳完啦</text>
      <button class="btn btn-outline btn-block" wx:if="{{team.is_creator}}" bindtap="doReopen">🔄 重新开放组队（有人退出时用）</button>
    </view>
    <view class="status-wrap" wx:if="{{team.status === 'cancelled'}}">
      <text style="color:var(--red);font-size:28rpx;font-weight:600;">❌ 该组队已取消</text>
    </view>
  </view>
</view>

<view class="loading" wx:if="{{!team}}">加载中...</view>
